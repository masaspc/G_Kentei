# PostgreSQL
POSTGRES_USER=g_kentei
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=g_kentei

# Backend
DATABASE_URL=postgresql+asyncpg://g_kentei:change_me_in_production@postgres:5432/g_kentei
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change_me_to_a_long_random_string

# Auth (single user)
# Generate the hash with: docker compose exec backend python -m app.cli.hash_password
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=

ANTHROPIC_API_KEY=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
